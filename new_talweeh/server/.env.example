# ── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=talweeh

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=                         # min 32 chars, random string

# ── App ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_ORIGIN=http://localhost:5174

# APP_BASE_URL is used to build password-reset links in emails.
# In development this can match FRONTEND_ORIGIN.
# In production set it to your public domain, e.g. https://talweehacademy.com
APP_BASE_URL=http://localhost:5174

# ── Email (Resend) ────────────────────────────────────────
# Sign up at https://resend.com and create an API key.
# In development you can send to your own address using onboarding@resend.dev as the from address.
# In production add and verify your domain in Resend (SPF / DKIM / DMARC) then update EMAIL_FROM.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Talweeh Academy <no-reply@your-domain.com>
# Optional: inbox for contact-form notifications (defaults to info@talweehacademy.com)
CONTACT_NOTIFY_EMAIL=info@talweehacademy.com

# ── YouTube (optional) ────────────────────────────────────
YOUTUBE_API_KEY=

# ── Media (optional, production only) ──────────────────────
# When set, requests to /wp-content/uploads/* are 302-redirected here instead
# of being served from public/ (used once self-hosted media is offloaded to
# object storage, e.g. Cloudflare R2). Leave unset for local development.
# Example: https://media.talweehacademy.com
MEDIA_BASE_URL=
